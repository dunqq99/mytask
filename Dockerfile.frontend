# Giai đoạn 1: Build React Frontend tĩnh
FROM node:20-alpine AS build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm install

COPY . .
RUN npm run build

# Giai đoạn 2: Serve bằng Nginx
FROM nginx:alpine

# Sao chép bản build tĩnh từ giai đoạn trước vào Nginx html
COPY --from=build /app/dist /usr/share/nginx/html

# Sao chép file cấu hình Nginx của chúng ta vào thư mục cấu hình mặc định
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
